# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

PORT=3000
MONGO_URI=mongodb://localhost:27017/leaflink
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Email OTP — create a Gmail App Password at myaccount.google.com/security
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=LeafLink <your_gmail@gmail.com>

# Security
CLIENT_URL=http://localhost:5173
OTP_EXPIRES_MINUTES=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
