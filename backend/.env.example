# Copy this file to .env and fill in your values
# NEVER commit the .env file to git

PORT=3000
MONGO_URI=mongodb://localhost:27017/leaflink
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Email OTP — create a Resend API Key at resend.com/api-keys
RESEND_API_KEY=re_your_api_key
EMAIL_USER=your_admin_email@gmail.com
EMAIL_FROM=LeafLink <onboarding@resend.dev>

# Note: EMAIL_USER is used to receive notifications when contact/job forms are submitted.
# EMAIL_FROM MUST be 'onboarding@resend.dev' on Resend's free tier unless you verify a domain.

# Security
CLIENT_URL=http://localhost:5173
OTP_EXPIRES_MINUTES=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
